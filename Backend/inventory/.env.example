# Local database connection (used when DATABASE_URL is not set)
PGHOST=localhost
PGUSER=postgres
PGDATABASE=pokemon_inventory
PGPASSWORD=your_password
PGPORT=5432

PORT=3000

# In production (e.g. Render) set a single connection string instead of the PG* vars above:
# DATABASE_URL=postgres://user:password@host:5432/dbname
