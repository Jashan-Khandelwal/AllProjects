<%- include('../partials/head') %>

<a class="back-link" href="/">← All types</a>

<div class="page-head">
  <h1 class="page-title" style="border-bottom: 4px solid <%= type.color %>;">
    <%= type.name %> Pokémon
  </h1>
  <div class="actions">
    <a class="btn btn-secondary" href="/types/<%= type.id %>/edit">Edit type</a>
    <form method="POST" action="/types/<%= type.id %>/delete" onsubmit="return confirm('Delete this type?');">
      <button type="submit" class="btn btn-danger">Delete</button>
    </form>
  </div>
</div>

<%- include('../partials/errors') %>

<% if (type.description) { %><p class="subtitle"><%= type.description %></p><% } %>

<% if (pokemon.length === 0) { %>
  <p class="empty">No Pokémon of this type yet.</p>
<% } else { %>
  <ul class="pokemon-grid">
    <% pokemon.forEach((p) => { %>
      <li class="pokemon-card">
        <a href="/pokemon/<%= p.id %>">
          <% if (p.image_url) { %><img src="<%= p.image_url %>" alt="<%= p.name %>" /><% } %>
          <span class="pokemon-name"><%= p.name %></span>
          <span class="pokemon-meta">Lv. <%= p.level %> · Qty <%= p.quantity %></span>
        </a>
      </li>
    <% }) %>
  </ul>
<% } %>

<%- include('../partials/footer') %>
