<%- include('../partials/head') %>

<a class="back-link" href="/trainers">← All trainers</a>

<div class="page-head">
  <h1 class="page-title"><%= trainer.name %></h1>
  <div class="actions">
    <a class="btn btn-secondary" href="/trainers/<%= trainer.id %>/edit">Edit trainer</a>
    <form method="POST" action="/trainers/<%= trainer.id %>/delete" onsubmit="return confirm('Delete this trainer? Their Pokémon will become wild.');">
      <button type="submit" class="btn btn-danger">Delete</button>
    </form>
  </div>
</div>
<% if (trainer.hometown) { %><p class="subtitle">From <%= trainer.hometown %></p><% } %>
<% if (trainer.bio) { %><p><%= trainer.bio %></p><% } %>

<h2 class="section-title"><%= trainer.name %>'s Pokémon</h2>
<% if (pokemon.length === 0) { %>
  <p class="empty">This trainer has no Pokémon.</p>
<% } else { %>
  <ul class="pokemon-grid">
    <% pokemon.forEach((p) => { %>
      <li class="pokemon-card">
        <a href="/pokemon/<%= p.id %>">
          <% if (p.image_url) { %><img src="<%= p.image_url %>" alt="<%= p.name %>" /><% } %>
          <span class="pokemon-name"><%= p.name %></span>
          <span class="pokemon-meta">Lv. <%= p.level %> · Qty <%= p.quantity %></span>
        </a>
      </li>
    <% }) %>
  </ul>
<% } %>

<%- include('../partials/footer') %>