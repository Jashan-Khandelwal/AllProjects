<%- include('../partials/head') %>

<a class="back-link" href="/pokemon">← All Pokémon</a>
<h1 class="page-title"><%= title %></h1>

<%- include('../partials/errors') %>

<form method="POST" action="<%= formAction %>" class="form">
  <label>
    Name
    <input type="text" name="name" value="<%= pokemon.name || '' %>" required maxlength="100" />
  </label>

  <label>
    Pokédex number
    <input type="number" name="dex_number" value="<%= pokemon.dex_number || '' %>" min="1" />
  </label>

  <label>
    Description
    <textarea name="description" rows="3"><%= pokemon.description || '' %></textarea>
  </label>

  <div class="form-row">
    <label>Level
      <input type="number" name="level" value="<%= pokemon.level || 5 %>" min="1" max="100" />
    </label>
    <label>Quantity
      <input type="number" name="quantity" value="<%= pokemon.quantity || 1 %>" min="0" />
    </label>
  </div>

  <label>
    Image URL
    <input type="text" name="image_url" value="<%= pokemon.image_url || '' %>" placeholder="https://..." />
  </label>

  <label>
    Trainer
    <select name="trainer_id">
      <option value="">— None (wild) —</option>
      <% trainers.forEach((tr) => { %>
        <option value="<%= tr.id %>" <%= String(pokemon.trainer_id) === String(tr.id) ? 'selected' : '' %>><%= tr.name %></option>
      <% }) %>
    </select>
  </label>

  <fieldset class="checkbox-group">
    <legend>Types <span class="hint">(pick 1–2)</span></legend>
    <% types.forEach((t) => { %>
      <label class="checkbox">
        <input type="checkbox" name="types" value="<%= t.id %>"
          <%= selectedTypeIds.map(String).includes(String(t.id)) ? 'checked' : '' %> />
        <span class="badge" style="background: <%= t.color %>"><%= t.name %></span>
      </label>
    <% }) %>
  </fieldset>

  <button type="submit" class="btn">Save</button>
</form>

<%- include('../partials/footer') %>
