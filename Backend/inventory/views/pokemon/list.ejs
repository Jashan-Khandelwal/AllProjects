<%- include('../partials/head') %>

<div class="page-head">
  <h1 class="page-title">All Pokémon</h1>
  <a class="btn" href="/pokemon/new">＋ New Pokémon</a>
</div>

<% if (pokemon.length === 0) { %>
  <p class="empty">No Pokémon yet.</p>
<% } else { %>
  <ul class="pokemon-grid">
    <% pokemon.forEach((p) => { %>
      <li class="pokemon-card">
        <a href="/pokemon/<%= p.id %>">
          <% if (p.image_url) { %><img src="<%= p.image_url %>" alt="<%= p.name %>" /><% } %>
          <span class="pokemon-name"><%= p.name %></span>
          <span class="pokemon-meta">Lv. <%= p.level %> · Qty <%= p.quantity %></span>
        </a>
      </li>
    <% }) %>
  </ul>
<% } %>

<%- include('../partials/footer') %>
