<%- include('../partials/head') %>
<div class="page-head">
  <h1>My Folders</h1>
  <a class="btn" href="/folders/new">+ New folder</a>
</div>

<% if (folders.length === 0) { %>
  <p class="muted">No folders yet. Create one to start uploading.</p>
<% } else { %>
  <ul class="folder-list">
    <% folders.forEach((folder) => { %>
      <li class="folder-row">
        <a class="folder-name" href="/folders/<%= folder.id %>">
          📁 <%= folder.name %>
        </a>
        <span class="muted"><%= folder._count.files %> file<%= folder._count.files === 1 ? '' : 's' %></span>
        <span class="row-actions">
          <a href="/folders/<%= folder.id %>/edit">Rename</a>
          <form action="/folders/<%= folder.id %>/delete" method="POST" class="inline"
                onsubmit="return confirm('Delete this folder and everything in it?');">
            <button type="submit" class="link-btn danger">Delete</button>
          </form>
        </span>
      </li>
    <% }) %>
  </ul>
<% } %>
<%- include('../partials/footer') %>
