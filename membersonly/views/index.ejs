<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Members Only</title>
  </head>
  <body>
    <% const isLoggedIn = !!locals.user; %> <% const isPremium = isLoggedIn &&
    (locals.user.membership_status === "premium" ||
    locals.user.membership_status === "admin"); %> <% const isAdmin = isLoggedIn
    && locals.user.membership_status === "admin"; %> <% if (isLoggedIn) { %>
    <h1>WELCOME BACK <%= locals.user.username %>!</h1>
    <p>
      Membership status: <strong><%= locals.user.membership_status %></strong>
    </p>
    <a href="/logout">LOG OUT</a>
    <hr />

    <% if (isPremium) { %>
    <h2>Post a message</h2>
    <form action="/post-message" method="POST">
      <label for="message">Your Message:</label><br />
      <textarea
        id="message"
        name="message"
        rows="4"
        cols="50"
        required
      ></textarea
      ><br />
      <button type="submit">Post Message</button>
    </form>
    <% } else { %>
    <p>Want to post messages? Join the club:</p>
    <a href="/jointheclub">Join the Club</a>
    <% } %> <% } else { %>
    <h1>Welcome to Members Only</h1>
    <p>Please log in or sign up to continue:</p>
    <a href="/login">Go to Login Page</a><br />
    <a href="/sign-up">Go to Signup Page</a>
    <% } %>

    <hr />
    <h3>All Messages</h3>
    <% if (locals.messages && locals.messages.length > 0) { %>
    <ul>
      <% locals.messages.forEach(msg => { %> <% if (isPremium) { %>
      <li>
        <strong><%= msg.username %></strong>
        <em>(<%= new Date(msg.created_at).toLocaleString('en-IN') %>)</em>: <%=
        msg.content %> <% if (isAdmin) { %>
        <form
          action="/delete-message/<%= msg.id %>"
          method="POST"
          style="display: inline"
        >
          <button type="submit">Delete</button>
        </form>
        <% } %>
      </li>
      <% } else { %>
      <li><%= msg.content %></li>
      <% } %> <% }) %>
    </ul>
    <% } else { %>
    <p>No messages yet.</p>
    <% } %>
  </body>
</html>
